{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "acf/teams",
  "version": "1.0.0",
  "title": "Equipo",
  "category": "theme",
  "icon": "groups",
  "description": "Muestra miembros del equipo en distintos estilos: cards, circular o minimalista.",
  "keywords": ["equipo", "team", "cards", "grid"],
  "supports": {
    "align": ["full"],
    "anchor": true,
    "className": true,
    "spacing": { "margin": false, "padding": false },
    "color": { "background": false, "text": false, "gradients": false },
    "typography": { "fontSize": false, "lineHeight": false }
  },
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    }
  },
  "acf": {
    "mode": "preview",
    "renderTemplate": "render.php",
    "validate": false,
    "blockVersion": 3
  },
  "styles": [
    { "name": "cards", "label": "Cards", "isDefault": true },
    { "name": "round", "label": "Circular" },
    { "name": "minimal", "label": "Minimalista" }
  ],
  "style": "file:./style.css",
  "editorStyle": "file:./editor.css"
}
