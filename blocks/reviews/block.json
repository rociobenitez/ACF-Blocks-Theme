{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "acf/reviews",
  "version": "1.0.0",
  "title": "Reseñas",
  "category": "theme",
  "icon": "star-filled",
  "description": "Muestra reseñas de clientes: Google (shortcode) o manuales (testimonios / cards).",
  "keywords": ["reseñas", "reviews", "testimonios", "opiniones"],
  "supports": {
    "align": ["full"],
    "anchor": true,
    "className": true,
    "spacing": { "margin": false, "padding": false },
    "color": { "background": false, "text": false, "gradients": false },
    "typography": { "fontSize": false, "lineHeight": false },
    "shadow": false
  },
  "styles": [
    { "name": "google", "label": "Google", "isDefault": true },
    { "name": "testimonials", "label": "Testimonios" },
    { "name": "cards", "label": "Cards" }
  ],
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    }
  },
  "acf": {
    "mode": "preview",
    "renderTemplate": "render.php",
    "validate": false,
    "blockVersion": 3
  },
  "example": {
    "attributes": {
      "className": "is-style-testimonials"
    }
  },
  "editorStyle": "file:./editor.css",
  "style": "file:./style.css"
}
