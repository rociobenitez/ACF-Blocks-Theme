{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "acf/cta",
  "version": "1.0.0",
  "title": "CTA",
  "category": "theme",
  "icon": "megaphone",
  "description": "Llamada a la acción con 3 variantes: banner (imagen de fondo), franja (color sólido) y split (imagen + contenido).",
  "keywords": ["cta", "banner", "llamada", "acción", "botón"],
  "supports": {
    "align": ["wide", "full"],
    "anchor": true,
    "className": true,
    "spacing": { "margin": false, "padding": false },
    "color": { "background": false, "text": false, "gradients": false },
    "typography": { "fontSize": false, "lineHeight": false }
  },
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    }
  },
  "styles": [
    { "name": "banner", "label": "Banner (imagen de fondo)", "isDefault": true },
    { "name": "strip",  "label": "Franja (fondo de color)" },
    { "name": "split",  "label": "Split (imagen + contenido)" }
  ],
  "acf": {
    "mode": "preview",
    "renderTemplate": "render.php",
    "validate": false,
    "blockVersion": 3
  },
  "style": "file:./style.css",
  "editorStyle": "file:./editor.css",
  "script": "file:./script.js"
}
