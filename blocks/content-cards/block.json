{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "acf/content-cards",
	"version": "1.0.0",
	"title": "Content Cards",
	"category": "theme",
	"icon": "grid-view",
	"description": "Grid de cards con imagen, título y descripción. Ideal para servicios, tratamientos o features.",
	"keywords": ["cards", "servicios", "grid", "tratamientos", "features"],
	"supports": {
		"align": ["full"],
		"anchor": true,
		"className": true,
		"color": false,
		"typography": false
	},
	"styles": [
		{ "name": "alternated", "label": "Alternado", "isDefault": true },
		{ "name": "grid", "label": "Grid" },
		{ "name": "grid-icons", "label": "Grid con iconos" },
		{ "name": "text-only", "label": "Solo texto" }
	],
	"acf": {
		"mode": "preview",
		"renderTemplate": "render.php"
	},
	"example": {
		"attributes": {
			"mode": "preview",
			"data": {
				"title": "Nuestros servicios",
				"description": "Soluciones adaptadas a tus necesidades"
			}
		}
	},
	"style": "file:./style.css",
	"editorStyle": "file:./editor.css"
}
