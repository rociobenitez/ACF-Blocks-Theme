{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "acf/text-section",
  "version": "1.0.0",
  "title": "Sección de Texto",
  "category": "theme",
  "icon": "text",
  "description": "Sección de contenido solo texto con variantes visuales. Sin imágenes.",
  "keywords": ["texto", "contenido", "sección", "cta", "intro"],
  "supports": {
    "align": ["full", "wide"],
    "anchor": true,
    "className": true,
    "spacing": { "margin": false, "padding": false },
    "color":   { "background": false, "text": false, "gradients": false },
    "typography": { "fontSize": false }
  },
  "styles": [
    { 
        "name": "centered",
        "label": "Centrado",
        "isDefault": true
    },
    { 
        "name": "split",
        "label": "Editorial (Split)"
    },
    { 
        "name": "highlight",
        "label": "Destacado (fondo color)"
    },
    { 
        "name": "large",
        "label": "Heading grande"
    },
    { 
        "name": "list",
        "label": "Lista de features"
    }
  ],
  "acf": {
    "mode": "preview",
    "renderTemplate": "render.php",
    "validate": false,
    "blockVersion": 3
  },
  "style":       "file:./style.css",
  "editorStyle": "file:./editor.css"
}
