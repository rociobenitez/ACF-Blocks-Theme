{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "acf/alternated-content",
	"version": "1.0.0",
	"title": "Contenido Alternado",
	"category": "theme",
	"icon": "align-pull-left",
	"description": "Sección con texto e imagen lado a lado. Imagen a izquierda o derecha, dentro del container o a borde completo.",
	"keywords": ["contenido", "imagen", "alternado", "split"],
	"supports": {
		"align": ["full"],
		"anchor": true,
		"className": true,
		"spacing": { "margin": false, "padding": false },
		"color": false,
		"typography": false
	},
	"styles": [
		{ "name": "default", "label": "Por defecto", "isDefault": true },
		{ "name": "rounded", "label": "Imagen redondeada" },
		{ "name": "shadow", "label": "Con sombra" }
	],
	"acf": {
		"mode": "preview",
		"renderTemplate": "render.php"
	},
	"example": {
		"attributes": {
			"mode": "preview",
			"data": {
				"tagline": "Sobre nosotros",
				"title": "Creamos experiencias únicas",
				"image_position": "right",
				"bg_color": "default",
				"padding_y": "md"
			}
		}
	},
	"style": "file:./style.css",
	"editorStyle": "file:./editor.css"
}
